# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Site URL (used in email links)
NEXT_PUBLIC_SITE_URL=https://yourdomain.fr

# Resend — transactional emails (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=MK Studio <noreply@yourdomain.fr>

# Web Push — admin push notifications on iPhone
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@yourdomain.fr

# Internal API secret (random string, used for cron & internal routes)
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=your_random_secret_here

# Vercel Cron secret (set in Vercel dashboard)
CRON_SECRET=your_cron_secret_here
